<launch>
<!-- Launch file for Livox MID360 LiDAR -->

	<arg name="rviz" default="true" />
	<arg name="build_2dmap" default="true" />
	<arg name="laser_scan_en" default="true" />
	<!-- true or false -->
	<rosparam command="load" file="$(find fast_lio_global)/config/mid360.yaml" />

	<param name="feature_extract_enable" type="bool" value="0"/>
	<param name="point_filter_num" type="int" value="3"/>
	<param name="max_iteration" type="int" value="3" />
	<param name="filter_size_surf" type="double" value="0.5" />
	<param name="filter_size_map" type="double" value="0.5" />
	<param name="cube_side_length" type="double" value="1000" />
	<param name="runtime_pos_log_enable" type="bool" value="0" />
	<!-- save 3dmap enable -->
    <param name="pcd_save/pcd_save_en" type="bool" value="true" />
    <node pkg="fast_lio_global" type="fastlio_mapping_global" name="laserMapping" output="screen" /> 


	<!-- publish robot position -->
	<param name="source_frame" type="str" value="/robot"/>
	<param name="target_frame" type="str" value="/robot_body"/>
	<param name="pub_topic" type="str" value="/robot_position"/>

	<param name="socket_print_en" type="bool" value="false"/>
	<param name="socket_en" type="bool" value="true"/>

	<!-- 雷达数据发送端（本机地址） -->
    <!-- <param name="server_addr" type="str" value="192.168.2.100"/> -->
    <param name="server_addr" type="str" value="127.0.0.1"/>
    <!-- 6001是接收雷达数据请求的端口 -->
    <param name="server_PORT" type="int" value="6001"/>
    
    <!-- 雷达数据接收端地址 -->
    <!-- <param name="client_addr" type="str" value="192.168.2.101"/> -->
    <param name="client_addr" type="str" value="127.0.0.1"/>
    <!-- 6002是对方接收雷达数据的端口 -->
    <param name="client_PORT" type="int" value="6002"/> 
	
	<node pkg="map_switch" type="tf_publish" name="tf_robot2map" output="screen" />

	<group if="$(arg rviz)">
	<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_lio_global)/rviz_cfg/loam_livox.rviz" />
	</group>

	<group if="$(arg build_2dmap)">
	<include file="$(find fast_lio_global)/launch/Pointcloud2Map.launch">
	</include>
	</group>

	<!-- point to laser -->
	<group if="$(arg laser_scan_en)">
		<include file="$(find pointcloud_to_laserscan)/launch/sample_node.launch">
		</include>
	</group>

	<node pkg="tf2_ros" type="static_transform_publisher" name="point2laserscan" args="0 0 0 0 0 0 /robot /point2scan" />

    <!-- 发布一个雷达初始位置camera_init到机器人足端初始位置robot的静态映射 -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="Init_IMU2robot" args="0 0 -0.52 0 0 0 /camera_init /robot" />
	 <!-- 发布一个雷达body到机器人足端robot_body的静态映射 -->
	<node pkg="tf2_ros" type="static_transform_publisher" name="body2robot" args="0 0 -0.52 0 0 0 /body /robot_body" />

</launch>
