<?xml version="1.0"?>
<launch>
    <!-- 雷达服务端 (LADDAR_OBJ) 基于 newdevice 框架 -->
    
    <!-- 网络配置 -->
    <arg name="laddar_ip" default="" />  <!-- 空字符串表示监听所有接口(INADDR_ANY) -->
    <arg name="laddar_port" default="8080" />
    <arg name="robot_ip" default="192.168.1.10" />
    <arg name="robot_port" default="9090" />
    
    <!-- ROS话题配置 -->
    <arg name="laser_topic" default="/mid360/scan" />
    <arg name="odom_topic" default="/Odometry" />
    
    <!-- 启动雷达服务端节点 -->
    <node name="laddar_server_node" 
          pkg="goal_sender" 
          type="laddar_server_node" 
          output="screen">
        
        <param name="laddar_ip" value="$(arg laddar_ip)" />
        <param name="laddar_port" value="$(arg laddar_port)" />
        <param name="robot_ip" value="$(arg robot_ip)" />
        <param name="robot_port" value="$(arg robot_port)" />
        <param name="laser_topic" value="$(arg laser_topic)" />
        <param name="odom_topic" value="$(arg odom_topic)" />
    </node>
    
</launch>
