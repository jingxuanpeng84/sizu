<?xml version="1.0"?>
<launch>
    <!-- 启动Livox驱动 -->
    <include file="$(find livox_ros_driver2)/launch_ROS1/msg_MID360.launch" />
    
    <!-- 启动FAST-LIO建图 -->
    <include file="$(find fast_lio_global)/launch/mapping_mid360.launch" />
    
    <!-- 启动RViz -->
    <node pkg="rviz" type="rviz" name="rviz" 
          args="-d $(find fast_lio_global)/rviz_cfg/mapping.rviz" />
    
    <!-- 等待RViz启动 -->
    <arg name="wait_time" default="5" />
    
    <!-- RViz窗口捕获（可选，需要安装mss库） -->
    <!-- <node pkg="rtsp_stream" type="rviz_capture.py" name="rviz_capture" output="screen">
        <param name="output_topic" value="/rviz/image" />
        <param name="fps" value="30" />
    </node> -->
    
    <!-- RTSP流服务器 -->
    <!-- 如果使用RViz捕获，使用/rviz/image话题 -->
    <!-- 如果使用相机图像，修改为实际的相机话题 -->
    <node pkg="rtsp_stream" type="rtsp_server.py" name="rtsp_stream_server" 
          output="screen" launch-prefix="bash -c 'sleep $(arg wait_time); $0 $@' ">
        <param name="image_topic" value="/camera/image_raw" />
        <param name="rtsp_port" value="8554" />
        <param name="stream_name" value="mapping" />
        <param name="fps" value="30" />
        <param name="width" value="1280" />
        <param name="height" value="720" />
        <param name="bitrate" value="2M" />
    </node>
    
    <node pkg="rtsp_stream" type="info_display.py" name="rtsp_info_display" 
          output="screen" launch-prefix="bash -c 'sleep $(arg wait_time); $0 $@' " />
</launch>
